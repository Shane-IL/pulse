{
  "name": "pulse-ui",
  "version": "0.1.0",
  "description": "A render-driven UI framework with virtual DOM and immutable stores",
  "type": "module",
  "main": "./dist/pulse.cjs",
  "module": "./dist/pulse.js",
  "exports": {
    ".": {
      "import": "./dist/pulse.js",
      "require": "./dist/pulse.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "ui",
    "framework",
    "virtual-dom",
    "vdom",
    "jsx",
    "state-management",
    "pulse"
  ],
  "license": "MIT",
  "devDependencies": {
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "jsdom": "^25.0.0"
  }
}
